{
  "menu_title": "Scouting",
  "background": "CAF FCs/assets/ui/backgrounds/scout_bg.png",

  "ui_elements": {

    "scout_button": {
      "label": "Scout Player",
      "position": { "x": 800, "y": 200 },
      "size": { "width": 300, "height": 80 },
      "script_link": "CAF FCs/modes/scouting/scouting_cooldown_ui.cs",
      "interactable": true
    },

    "cooldown_text": {
      "position": { "x": 800, "y": 300 },
      "font_size": 24,
      "color": "#FFFFFF",
      "default_text": "Checking scouting availability..."
    },

    "player_preview_panel": {
      "position": { "x": 400, "y": 250 },
      "size": { "width": 350, "height": 500 },
      "show_attributes": true,
      "show_card_type": true,
      "show_player_image": true
    },

    "weekly_info_text": {
      "position": { "x": 400, "y": 750 },
      "font_size": 20,
      "color": "#FFD700",
      "text": "You can scout one player every 7 days."
    }

  },

  "parameters": {
    "auto_update_ui_interval_sec": 1,
    "max_weekly_scout": 1,
    "cooldown_days": 7,
    "cooldown_display_format": "{days}d {hours}h {minutes}m {seconds}s"
  }
}
