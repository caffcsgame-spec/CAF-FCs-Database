{
  "version": "1.0",

  "general": {
    "default_fov": 60,
    "min_fov": 50,
    "max_fov": 75,
    "camera_height": 8.0,
    "camera_distance": 12.0,
    "camera_smooth_speed": 5.0,
    "rotation_smooth_speed": 4.0
  },

  "tracking": {
    "player_follow": true,
    "ball_focus": true,
    "blend_player_ball": 0.7,
    "look_ahead_distance": 3.0,
    "height_offset": 1.5
  },

  "dynamic_adjustments": {
    "speed_based_fov": {
      "enabled": true,
      "min_speed": 0.0,
      "max_speed": 10.0,
      "fov_min": 55,
      "fov_max": 70
    },
    "zoom_on_action": {
      "enabled": true,
      "kick_zoom_amount": 2.0,
      "tackle_zoom_amount": 1.5,
      "goal_zoom_amount": 3.0
    }
  },

  "collision": {
    "avoid_obstacle": true,
    "raycast_offset": 0.5,
    "camera_pushback_speed": 8.0
  },

  "mobile_touch_support": {
    "pinch_to_zoom": true,
    "swipe_to_rotate": true,
    "double_tap_reset": true
  },

  "gamepad_support": {
    "right_stick_rotate": true,
    "zoom_axis": "R2_L2"
  }
}
