{
  "gameplay_settings": {

    "match": {
      "match_duration_minutes": {
        "options": [4, 6, 8, 10, 12, 15],
        "default": 12
      },
      "halftime_break_seconds": 20,
      "extra_time_enabled": true,
      "penalties_enabled": true
    },

    "difficulty": {
      "levels": [
        "beginner",
        "amateur",
        "professional",
        "world_class",
        "legendary"
      ],
      "default": "professional"
    },

    "game_speed": {
      "options": [
        "slow",
        "normal",
        "fast",
        "realistic"
      ],
      "default": "realistic"
    },

    "player_fatigue_system": {
      "stamina_drain_rate": 1.0,
      "sprint_drain_multiplier": 1.8,
      "recovery_rate": 0.6,
      "injury_risk_when_low_stamina": true
    },

    "injuries": {
      "enabled": true,
      "frequency": 0.35,
      "types": [
        "minor",
        "moderate",
        "severe"
      ]
    },

    "referee": {
      "strictness_level": {
        "options": [
          "lenient",
          "balanced",
          "strict"
        ],
        "default": "balanced"
      },
      "foul_detection_sensitivity": 0.75,
      "handball_enabled": true,
      "advantage_rule": true,
      "var_system_enabled": true
    },

    "ball_physics": {
      "ball_speed": 1.0,
      "shot_power_multiplier": 1.0,
      "curve_effect_strength": 1.2,
      "wind_influence": false,
      "ground_friction": 0.9
    },

    "passing_system": {
      "pass_assist": {
        "options": [
          "off",
          "semi",
          "full"
        ],
        "default": "semi"
      },
      "pass_error_rate": 0.15,
      "through_ball_accuracy": 0.85,
      "first_touch_error": 0.2
    },

    "shooting_system": {
      "shot_assist": {
        "options": [
          "off",
          "semi",
          "full"
        ],
        "default": "semi"
      },
      "shot_error_rate": 0.18,
      "long_shot_accuracy": 0.75,
      "volley_accuracy": 0.7
    },

    "defending_system": {
      "auto_defending": {
        "options": [
          "off",
          "semi",
          "full"
        ],
        "default": "semi"
      },
      "tackle_success_rate": 0.8,
      "slide_tackle_risk": 0.4,
      "defensive_positioning_ai": 0.9
    },

    "goalkeeper_ai": {
      "reaction_speed": 0.9,
      "save_accuracy": 0.85,
      "rush_out_decision_rate": 0.6,
      "parry_frequency": 0.4
    },

    "ai_behavior": {
      "attacking_creativity": 0.85,
      "dribbling_attempts": 0.75,
      "long_pass_usage": 0.6,
      "cross_frequency": 0.7,
      "pressing_intensity": 0.8,
      "counter_attack_probability": 0.7
    },

    "skill_moves": {
      "enabled": true,
      "success_rate": 0.85,
      "stamina_cost": 0.08
    },

    "position_based_experience": {
      "enabled": true,
      "position_bonus_multiplier": 1.3,
      "out_of_position_penalty": 0.25
    },

    "squad_synergy": {
      "enabled": true,
      "same_club_bonus": 0.1,
      "same_country_bonus": 0.08,
      "same_league_bonus": 0.05,
      "max_team_bonus": 0.25
    }

  }
}
