// UE_PlayerCardManager.h
#pragma once

#include "CoreMinimal.h"
#include "UObject/NoExportTypes.h"
#include "PlayerCardWidget.h"
#include "Engine/DataTable.h"
#include "UE_PlayerCardManager.generated.h"

UCLASS(Blueprintable)
class CAF_FC_DATABASE_API UUE_PlayerCardManager : public UObject
{
    GENERATED_BODY()

public:
    // Constructor
    UUE_PlayerCardManager();

    // Widget Blueprint class reference
    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category="Player Cards")
    TSubclassOf<UPlayerCardWidget> CardWidgetClass;

    // All active player card widgets
    UPROPERTY(BlueprintReadOnly, Category="Player Cards")
    TArray<UPlayerCardWidget*> ActiveCards;

    // Player Database
    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category="Player Cards")
    TArray<FPlayerData> PlayerDatabase;

    // Spawn a card for a specific player
    UFUNCTION(BlueprintCallable, Category="Player Cards")
    UPlayerCardWidget* SpawnCardForPlayer(int32 PlayerID);

    // Spawn all cards in database
    UFUNCTION(BlueprintCallable, Category="Player Cards")
    void SpawnAllCards(UUserWidget* ParentWidget);

private:
    // Internal helper
    UPlayerCardWidget* CreateCard(const FPlayerData& PlayerData, UUserWidget* ParentWidget);
};
