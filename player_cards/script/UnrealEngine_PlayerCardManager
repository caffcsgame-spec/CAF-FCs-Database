// UE_PlayerCardManager.cpp
#include "UE_PlayerCardManager.h"
#include "Blueprint/UserWidget.h"

UUE_PlayerCardManager::UUE_PlayerCardManager()
{
    ActiveCards = TArray<UPlayerCardWidget*>();
    PlayerDatabase = TArray<FPlayerData>();
}

UPlayerCardWidget* UUE_PlayerCardManager::SpawnCardForPlayer(int32 PlayerID)
{
    if (!CardWidgetClass) return nullptr;

    for (const FPlayerData& Data : PlayerDatabase)
    {
        // Chagua player kwa ID
        // Hapa tunassuming PlayerID = index+1
        if (PlayerID == PlayerDatabase.IndexOfByKey(Data)+1)
        {
            // Temporary parent = nullptr
            return CreateCard(Data, nullptr);
        }
    }
    return nullptr;
}

void UUE_PlayerCardManager::SpawnAllCards(UUserWidget* ParentWidget)
{
    if (!CardWidgetClass) return;

    for (const FPlayerData& Data : PlayerDatabase)
    {
        UPlayerCardWidget* Card = CreateCard(Data, ParentWidget);
        if (Card) ActiveCards.Add(Card);
    }
}

UPlayerCardWidget* UUE_PlayerCardManager::CreateCard(const FPlayerData& PlayerData, UUserWidget* ParentWidget)
{
    if (!CardWidgetClass) return nullptr;

    UPlayerCardWidget* NewCard = CreateWidget<UPlayerCardWidget>(ParentWidget, CardWidgetClass);
    if (!NewCard) return nullptr;

    NewCard->SetupCard(PlayerData);
    if (ParentWidget)
    {
        NewCard->AddToViewport();
    }

    return NewCard;
}
