#include "UE_PlayerCardWidget.h"
#include "Components/Image.h"
#include "Components/TextBlock.h"
#include "Engine/Texture2D.h"
#include "Kismet/KismetRenderingLibrary.h"

void UUE_PlayerCardWidget::SetupCard(const FPlayerData& PlayerData)
{
    CurrentPlayerData = PlayerData;

    if (PlayerNameText)
    {
        PlayerNameText->SetText(FText::FromString(PlayerData.Name));
    }

    if (PositionText)
    {
        PositionText->SetText(FText::FromString(PlayerData.Position));
    }

    if (AgeText)
    {
        AgeText->SetText(FText::AsNumber(PlayerData.Age));
    }

    // Optional: set images if paths exist
    if (PlayerPhoto && !PlayerData.PhotoPath.IsEmpty())
    {
        UTexture2D* Texture = Cast<UTexture2D>(StaticLoadObject(UTexture2D::StaticClass(), nullptr, *PlayerData.PhotoPath));
        if (Texture) PlayerPhoto->SetBrushFromTexture(Texture);
    }

    if (ClubLogo && !PlayerData.ClubLogoPath.IsEmpty())
    {
        UTexture2D* Texture = Cast<UTexture2D>(StaticLoadObject(UTexture2D::StaticClass(), nullptr, *PlayerData.ClubLogoPath));
        if (Texture) ClubLogo->SetBrushFromTexture(Texture);
    }

    if (CountryFlag && !PlayerData.CountryFlagPath.IsEmpty())
    {
        UTexture2D* Texture = Cast<UTexture2D>(StaticLoadObject(UTexture2D::StaticClass(), nullptr, *PlayerData.CountryFlagPath));
        if (Texture) CountryFlag->SetBrushFromTexture(Texture);
    }

    // Set card background depending on rarity
    if (CardBackground)
    {
        FString Path;
        if (PlayerData.CardType.Equals("Epic"))
            Path = "/Game/PlayerCards/Textures/EpicCardBG.EpicCardBG";
        else if (PlayerData.CardType.Equals("Rare"))
            Path = "/Game/PlayerCards/Textures/RareCardBG.RareCardBG";
        else
            Path = "/Game/PlayerCards/Textures/CommonCardBG.CommonCardBG";

        UTexture2D* BGTexture = Cast<UTexture2D>(StaticLoadObject(UTexture2D::StaticClass(), nullptr, *Path));
        if (BGTexture) CardBackground->SetBrushFromTexture(BGTexture);
    }
}
